# ============================================================
# AegisAPI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# === Gateway ===
PORT=5000
NODE_ENV=development

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Database (Supabase Cloud — primary) ===
# Leave empty to use local Postgres fallback
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# === Database (Local Postgres — fallback, used when SUPABASE_URL is empty) ===
LOCAL_PG_HOST=localhost
LOCAL_PG_PORT=5433
LOCAL_PG_USER=aegis
LOCAL_PG_PASSWORD=aegis_secure_password
LOCAL_PG_DATABASE=aegisdb

# === AI Threat Analyzer ===
# Supports any OpenAI-compatible endpoint:
#   NVIDIA NIM:  https://integrate.api.nvidia.com/v1
#   OpenAI:      https://api.openai.com/v1
#   Groq:        https://api.groq.com/openai/v1
#   Mistral:     https://api.mistral.ai/v1
#   Ollama:      http://localhost:11434/v1
AI_PROVIDER_BASE_URL=https://integrate.api.nvidia.com/v1
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=meta/llama-3.1-70b-instruct

# === Request Logging ===
# Set to 'true' to log ALL requests (clean + blocked) to the access_log table
LOG_ALL_REQUESTS=false

# === Rate Limiting ===
RATE_LIMIT_PER_MIN=100

# === Performance ===
# Set to 'true' to fork one worker per CPU core (scales linearly)
CLUSTER_MODE=false
# Number of workers (0 = auto-detect CPU cores)
CLUSTER_WORKERS=0
# Set to 'true' if behind a reverse proxy (Nginx, Cloudflare, etc.)
TRUST_PROXY=false
# Allowed origin for CORS (* = all, or specify https://yourdomain.com)
CORS_ORIGIN=*

# === Dashboard (Next.js) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GATEWAY_URL=http://localhost:5000
